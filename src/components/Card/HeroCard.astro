---
interface CardProps {
  title: string;
  description: string;
  image?: string;
  socials?: string[];
}
interface socialItem {
  icon: string;
  link: string;
}

const { title, description, image, socials } = Astro.props as CardProps;

const SocialLinks: Record<string, socialItem[]> = {
  linkedin: [
    { icon: "", link: "https://www.linkedin.com/in/vitor-oliveira-0a1b2b1a3/" },
  ],
  github: [{ icon: "", link: "" }],
};
---

<div
  class="flex min-w-5xl h-80 border border-border-muted gap-4 bg-bg-surface rounded-lg shadow-lg"
>
  <div
    class="flex justify-around max-w-prose flex-col gap-4 p-4 border border-yellow-300"
  >
    <div class="flex flex-col gap-4">
      <h2 class="text-4xl font-bold font-display">{title}</h2>
      <p class="text-gray-600">{description}</p>
    </div>
    {
      socials && (
        <div class="flex gap-2 mt-4">
          {socials.map((socialKey) => {
            const socialDataList = SocialLinks[socialKey];
            const socialItem = socialDataList && socialDataList[0];

            return socialItem && socialItem.link ? (
              <a class="text-xs" href={socialItem.link}>
                {" "}
                {socialItem.icon} <span class="uppercase">{socialKey}</span>
              </a>
            ) : null;
          })}
        </div>
      )
    }
  </div>
  <div class="w-1/3 h-full border border-green-300"></div>
</div>
