---
import { getCollection } from "astro:content";
import BlogCard from "../BlogCard/BlogCard.astro";

const posts = await getCollection("blog");
---

<article class="min-w-5xl gap-6 flex-center flex-col p-2">
  {
    posts.map((post) => {
      return (
        <BlogCard
          title={post.data.title}
          shortDesc={post.data.description}
          date={post.data.date.toLocaleDateString("pt-BR", {
            month: "short",
            year: "2-digit",
          })}
          topic={post.data.topic}
          tags={post.data.tags}
        />
      );
    })
  }
</article>
