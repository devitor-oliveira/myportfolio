---
interface BlogCardProps {
	slug: string;
	title: string;
	shortDesc: string;
	date: string;
	topic?: string;
	tags?: string[];
}

const { title, slug, shortDesc, date, topic, tags } =
	Astro.props as BlogCardProps;
---

<article
  class="w-3xl group max-w-5xl cursor-pointer py-4 px-6 bg-bg-surface
  hover:bg-bg-surface-hover flex flex-col gap-2 border border-white/50 hover:border-brand-hover"
>
  <!-- ASsunto + data -->
  <header
    class="flex font-detail tracking-widest justify-between w-full text-xs"
  >
    {
      topic ? (
        <span class="uppercase group-hover:text-brand-hover   text-text-muted ">
          [{topic}]
        </span>
      ) : null
    }
    {
      date ? (
        <time
          class=" group-hover:text-brand-hover  text-text-muted uppercase"
          datetime={date}
        >
          {date}
        </time>
      ) : null
    }
  </header>
  <!-- corpo: titulo + descrição -->
  <div class="flex flex-col gap-3">
    <a href={`/blog/${slug}`} target="_blank" class="w-fit">
      <h3 class="font-display text-[22px]">{title}</h3>
    </a>
    <p class="text-text-main/75 text-sm">{shortDesc}</p>
  </div>

  <!-- Footer: tags -->
  <aside class="flex pt-4 gap-2 mt-2 border-t border-border-muted-alt">
    {
      tags
        ? tags.map((tag) => {
            return (
              <span class="uppercase p-1 border border-text-muted/80 bg-bg-surface-hover text-text-main/60 font-medium font-detail text-xs tracking-wide">
                {tag}
              </span>
            );
          })
        : null
    }
  </aside>
</article>
