---
import BlogList from "@/components/BlogList/BlogList.astro";
import ContentClient from "@/components/ContentClient";
import HeroCard from "../components/Card/HeroCard.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <!-- <main class="flex-center flex-col border border-amber-200"> -->
  <main class="flex flex-col h-full w-full">
    <!-- Hero -->
    <section class="flex-center min-h-100">
      <HeroCard
        title="Programmming and Automative tasks"
        description="Arquitetura CI/CD robusta utilizando GitHub Actions e AWS para automação de entrega contínua, reduzindo o tempo de build em ambientes de produção."
        socials={["linkedin", "GitHub Actions", "AWS", "Automação"]}
      />
    </section>
    <!-- Content Section -->
    <section class="flex-center">
      <ContentClient client:load>
        <div slot="blogContentSlot"><BlogList /></div>
        <div slot="projectContentSlot">Under development</div>
      </ContentClient>
    </section>
  </main>
</Layout>
